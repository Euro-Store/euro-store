{
  "expo": {
    "name": "Euro Store",
    "slug": "euro-store",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "eurostore",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.eurostore.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.eurostore.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        { "backgroundColor": "#0a0a0a", "image": "./assets/images/splash-icon.png" }
      ]
    ],
    "experiments": { "typedRoutes": true }
  }
}
