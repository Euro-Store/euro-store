// ⚠ هذا schema خاص بـ Partner Portal فقط
// إضافات مطلوبة في الـ schema المشترك:
//   1. أضف  PARTNER  إلى enum Role
//   2. أضف  PartnerUser model
//   3. أضف  qrToken String @unique  إلى Exchange model
//   4. شغّل: npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  CUSTOMER
  HELPER
  PARTNER
  ADMIN
}

enum ExchangeStatus {
  PENDING
  CONFIRMED_BY_HELPER
  CONFIRMED_BY_PARTNER
  IN_STORE_EXCHANGE
  IN_TRANSIT
  DELIVERED
  COMPLETED
  REJECTED
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  role        Role         @default(CUSTOMER)
  createdAt   DateTime     @default(now())
  partnerUser PartnerUser?
  exchanges   Exchange[]
}

model PartnerUser {
  id        String   @id @default(cuid())
  userId    String   @unique
  shopName  String
  area      String
  phone     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Exchange {
  id         String         @id @default(cuid())
  qrToken    String         @unique @default(cuid())
  status     ExchangeStatus @default(PENDING)
  reason     String?
  customerId String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  customer   User           @relation(fields: [customerId], references: [id])
  items      ExchangeItem[]
}

model ExchangeItem {
  id         String   @id @default(cuid())
  exchangeId String
  productId  String
  size       String?
  quantity   Int      @default(1)
  exchange   Exchange @relation(fields: [exchangeId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
}

model Product {
  id     String         @id @default(cuid())
  name   String
  images ProductImage[]
  items  ExchangeItem[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  isMain    Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id])
}