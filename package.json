{
  "name": "euro-store",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web":    "turbo run dev --filter=@euro/web",
    "dev:admin":  "turbo run dev --filter=admin",
    "dev:helper": "turbo run dev --filter=helper",
    "build":      "turbo run build",
    "lint":       "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.9.14"
  }
}